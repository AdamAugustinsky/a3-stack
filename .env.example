# Environment Variables for BestestStack

# Public server URL for the web frontend to connect to the API
# This is used at build time for the SvelteKit app
PUBLIC_SERVER_URL=http://localhost:4000

# Database configuration
DATABASE_URL=postgresql://postgres:password@postgres:5432/besteststack

# CORS configuration
CORS_ORIGIN=http://localhost:4001

# Authentication configuration
BETTER_AUTH_SECRET=your-secret-key-here
BETTER_AUTH_URL=http://localhost:4000

# Node environment
NODE_ENV=production