{
  "name": "besteststack",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "check": "oxlint",
    "dev": "turbo -F web dev",
    "build": "turbo -F web build",
    "check-types": "turbo -F web check-types",
    "db:push": "turbo -F web db:push",
    "db:studio": "turbo -F web db:studio",
    "db:generate": "turbo -F web db:generate",
    "db:migrate": "turbo -F web db:migrate",
    "db:start": "turbo -F web db:start",
    "db:watch": "turbo -F web db:watch",
    "db:stop": "turbo -F web db:stop",
    "db:down": "turbo -F web db:down"
  },
  "dependencies": {},
  "devDependencies": {
    "turbo": "^2.5.4",
    "oxlint": "^1.8.0"
  },
  "packageManager": "bun@1.2.7"
}
